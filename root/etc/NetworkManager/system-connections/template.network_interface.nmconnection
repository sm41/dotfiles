[connection]
id=${NETWORK_INTERFACE}
type=ethernet
interface-name=${NETWORK_INTERFACE}
autoconnect=true

[ipv4]
method=manual
address1=${IPADDR},192.168.1.1
dns=1.1.1.2;1.0.0.2;
ignore-auto-dns=true

[ipv6]
method=auto
ip6-privacy=2
dns=2606:4700:4700::1112;2606:4700:4700::1002;
ignore-auto-dns=true

[proxy]